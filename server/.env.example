# Server Configuration
PORT=5001

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT Secret Key (Generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Cashfree Payment Gateway Configuration
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_ENVIRONMENT=SANDBOX
# Use 'PRODUCTION' for production environment, 'SANDBOX' for testing

# Admin: Create admin user on first run (e.g. via seed or first registration + role change).
# Do NOT commit real credentials. Leave empty or set in .env only.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# Application URLs
BASE_URL=http://localhost:5001
# Base URL for payment callbacks (backend server URL)
# Production: https://apis.chatbot.nvhotech.in

Web_url=http://localhost:5173
# Frontend URL for payment success/failure redirects and OAuth callback redirect
# Production: https://chatbot.nvhotech.in

# API base URL (used for OAuth redirect_uri). Set in production so Google callback hits the right host.
# API_URL=http://localhost:5001
# Production: API_URL=https://apis.chatbot.nvhotech.in

# Google OAuth (Phase 5.8 — Sign in with Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI: https://apis.chatbot.nvhotech.in/api/users/auth/google/callback

# SMTP Configuration (Zoho)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-zoho-app-password
SMTP_FROM="ChatBot Support" <your-email@yourdomain.com>

# Email branding (logo inside the email body)
# For inline logo attachments (recommended): keep defaults; it will use /public/logoNT512.png automatically.
EMAIL_LOGO_CID=brandlogo
# Optional absolute path override if you want a different local logo file.
# EMAIL_LOGO_PATH=/absolute/path/to/logo.png
#
# Alternative: external logo URL (must be public https). If set, it will be used when no CID is available.
# EMAIL_LOGO_URL=https://yourdomain.com/logo.png
EMAIL_BRAND_NAME="ChatBot Support"

# Optional: show your company logo inside the email body (Gmail sender avatar is separate; see BIMI).
# Must be an absolute https URL to a publicly accessible image (png/jpg/webp).
EMAIL_LOGO_URL=
# Optional: brand name shown in the email header.
EMAIL_BRAND_NAME="ChatBot Support"

# Optional: Data retention (days). Audit logs and cache older than this are deleted by retention job.
# DATA_RETENTION_DAYS=90

# Optional: Sentry error tracking (set SENTRY_DSN to enable)
# SENTRY_DSN=
